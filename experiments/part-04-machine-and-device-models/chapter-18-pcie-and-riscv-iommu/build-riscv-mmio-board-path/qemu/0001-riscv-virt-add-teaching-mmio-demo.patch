diff --git a/hw/misc/qb_mmio_demo.c b/hw/misc/qb_mmio_demo.c
new file mode 100644
index 0000000..691a360
--- /dev/null
+++ b/hw/misc/qb_mmio_demo.c
@@ -0,0 +1,170 @@
+/*
+ * QEMU Book teaching MMIO device
+ *
+ * This is a deliberately small teaching model, not an upstream device ABI.
+ *
+ * SPDX-License-Identifier: GPL-2.0-or-later
+ */
+
+#include "qemu/osdep.h"
+#include "hw/misc/qb_mmio_demo.h"
+#include "migration/vmstate.h"
+#include "qemu/log.h"
+#include "qemu/module.h"
+
+struct QBMMIODemoState {
+    SysBusDevice parent_obj;
+
+    MemoryRegion mmio;
+    qemu_irq irq;
+    uint32_t control;
+    uint32_t data;
+    bool pending;
+};
+
+static void qb_mmio_demo_update_irq(QBMMIODemoState *s)
+{
+    bool level = s->pending &&
+                 (s->control & QB_MMIO_DEMO_CONTROL_IRQ_ENABLE);
+
+    qemu_set_irq(s->irq, level);
+}
+
+static uint64_t qb_mmio_demo_read(void *opaque, hwaddr offset,
+                                  unsigned int size)
+{
+    QBMMIODemoState *s = opaque;
+
+    switch (offset) {
+    case QB_MMIO_DEMO_REG_ID:
+        return QB_MMIO_DEMO_ID_VALUE;
+    case QB_MMIO_DEMO_REG_CONTROL:
+        return s->control;
+    case QB_MMIO_DEMO_REG_STATUS:
+        return s->pending ? QB_MMIO_DEMO_STATUS_PENDING : 0;
+    case QB_MMIO_DEMO_REG_DATA:
+        return s->data;
+    default:
+        qemu_log_mask(LOG_GUEST_ERROR,
+                      "%s: bad read at offset 0x%" HWADDR_PRIx "\n",
+                      TYPE_QB_MMIO_DEMO, offset);
+        return 0;
+    }
+}
+
+static void qb_mmio_demo_write(void *opaque, hwaddr offset, uint64_t value,
+                               unsigned int size)
+{
+    QBMMIODemoState *s = opaque;
+
+    switch (offset) {
+    case QB_MMIO_DEMO_REG_CONTROL:
+        s->control = value & QB_MMIO_DEMO_CONTROL_MASK;
+        break;
+    case QB_MMIO_DEMO_REG_STATUS:
+        if (value & QB_MMIO_DEMO_STATUS_PENDING) {
+            s->pending = false;
+        }
+        break;
+    case QB_MMIO_DEMO_REG_DATA:
+        s->data = value & QB_MMIO_DEMO_DATA_MASK;
+        break;
+    case QB_MMIO_DEMO_REG_DOORBELL:
+        if ((value & 1) &&
+            (s->control & QB_MMIO_DEMO_CONTROL_ENABLE)) {
+            s->pending = true;
+        }
+        break;
+    default:
+        qemu_log_mask(LOG_GUEST_ERROR,
+                      "%s: bad write at offset 0x%" HWADDR_PRIx "\n",
+                      TYPE_QB_MMIO_DEMO, offset);
+        return;
+    }
+
+    qb_mmio_demo_update_irq(s);
+}
+
+static const MemoryRegionOps qb_mmio_demo_ops = {
+    .read = qb_mmio_demo_read,
+    .write = qb_mmio_demo_write,
+    .endianness = DEVICE_LITTLE_ENDIAN,
+    .valid = {
+        .min_access_size = 4,
+        .max_access_size = 4,
+        .unaligned = false,
+    },
+};
+
+static void qb_mmio_demo_reset_enter(Object *obj, ResetType type)
+{
+    QBMMIODemoState *s = QB_MMIO_DEMO(obj);
+
+    s->control = 0;
+    s->data = 0;
+    s->pending = false;
+}
+
+static void qb_mmio_demo_reset_hold(Object *obj, ResetType type)
+{
+    QBMMIODemoState *s = QB_MMIO_DEMO(obj);
+
+    qb_mmio_demo_update_irq(s);
+}
+
+static int qb_mmio_demo_post_load(void *opaque, int version_id)
+{
+    QBMMIODemoState *s = opaque;
+
+    qb_mmio_demo_update_irq(s);
+    return 0;
+}
+
+static const VMStateDescription vmstate_qb_mmio_demo = {
+    .name = TYPE_QB_MMIO_DEMO,
+    .version_id = 1,
+    .minimum_version_id = 1,
+    .post_load = qb_mmio_demo_post_load,
+    .fields = (const VMStateField[]) {
+        VMSTATE_UINT32(control, QBMMIODemoState),
+        VMSTATE_UINT32(data, QBMMIODemoState),
+        VMSTATE_BOOL(pending, QBMMIODemoState),
+        VMSTATE_END_OF_LIST()
+    },
+};
+
+static void qb_mmio_demo_init(Object *obj)
+{
+    QBMMIODemoState *s = QB_MMIO_DEMO(obj);
+    SysBusDevice *sbd = SYS_BUS_DEVICE(obj);
+
+    memory_region_init_io(&s->mmio, obj, &qb_mmio_demo_ops, s,
+                          TYPE_QB_MMIO_DEMO, QB_MMIO_DEMO_MMIO_SIZE);
+    sysbus_init_mmio(sbd, &s->mmio);
+    sysbus_init_irq(sbd, &s->irq);
+}
+
+static void qb_mmio_demo_class_init(ObjectClass *oc, const void *data)
+{
+    DeviceClass *dc = DEVICE_CLASS(oc);
+    ResettableClass *rc = RESETTABLE_CLASS(oc);
+
+    dc->vmsd = &vmstate_qb_mmio_demo;
+    rc->phases.enter = qb_mmio_demo_reset_enter;
+    rc->phases.hold = qb_mmio_demo_reset_hold;
+}
+
+static const TypeInfo qb_mmio_demo_info = {
+    .name = TYPE_QB_MMIO_DEMO,
+    .parent = TYPE_SYS_BUS_DEVICE,
+    .instance_size = sizeof(QBMMIODemoState),
+    .instance_init = qb_mmio_demo_init,
+    .class_init = qb_mmio_demo_class_init,
+};
+
+static void qb_mmio_demo_register_types(void)
+{
+    type_register_static(&qb_mmio_demo_info);
+}
+
+type_init(qb_mmio_demo_register_types)
