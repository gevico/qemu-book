+static void create_fdt_qb_mmio_demo(RISCVVirtState *s,
+                                    uint32_t irq_mmio_phandle)
+{
+    MachineState *ms = MACHINE(s);
+    g_autofree char *name = NULL;
+
+    name = g_strdup_printf("/soc/qb-mmio-demo@%" HWADDR_PRIx,
+                           s->memmap[VIRT_QB_MMIO_DEMO].base);
