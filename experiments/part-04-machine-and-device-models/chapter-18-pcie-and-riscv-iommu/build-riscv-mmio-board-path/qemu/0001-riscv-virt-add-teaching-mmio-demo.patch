diff --git a/tests/qtest/qb-mmio-demo-test.c b/tests/qtest/qb-mmio-demo-test.c
new file mode 100644
index 0000000..0c95377
--- /dev/null
+++ b/tests/qtest/qb-mmio-demo-test.c
@@ -0,0 +1,97 @@
+/*
+ * QEMU Book teaching MMIO device qtest
+ *
+ * SPDX-License-Identifier: GPL-2.0-or-later
+ */
+
+#include "qemu/osdep.h"
+#include "libqtest.h"
+#include "hw/misc/qb_mmio_demo.h"
+
+#define QB_MMIO_DEMO_BASE      0x10010000
+#define VIRT_PLIC_PENDING_BASE 0x0c001000
+#define VIRT_QB_MMIO_DEMO_IRQ  12
+
+static QTestState *qb_mmio_demo_start(void)
+{
+    return qtest_init("-machine virt,qb-mmio-demo=on -display none");
+}
+
+static void test_opt_in_default(void)
+{
+    QTestState *qts = qtest_init("-machine virt -display none");
+
+    g_assert_cmphex(qtest_readl(qts, QB_MMIO_DEMO_BASE +
+                                QB_MMIO_DEMO_REG_ID), !=,
+                    QB_MMIO_DEMO_ID_VALUE);
+
+    qtest_quit(qts);
+}
+
+static void test_register_masks(void)
+{
+    QTestState *qts = qb_mmio_demo_start();
+
+    g_assert_cmphex(qtest_readl(qts, QB_MMIO_DEMO_BASE +
+                                QB_MMIO_DEMO_REG_ID), ==,
+                    QB_MMIO_DEMO_ID_VALUE);
+
+    qtest_writel(qts, QB_MMIO_DEMO_BASE + QB_MMIO_DEMO_REG_CONTROL,
+                 0xffffffff);
+    g_assert_cmphex(qtest_readl(qts, QB_MMIO_DEMO_BASE +
+                                QB_MMIO_DEMO_REG_CONTROL), ==,
+                    QB_MMIO_DEMO_CONTROL_MASK);
+
+    qtest_writel(qts, QB_MMIO_DEMO_BASE + QB_MMIO_DEMO_REG_DATA,
+                 0xffffffff);
+    g_assert_cmphex(qtest_readl(qts, QB_MMIO_DEMO_BASE +
+                                QB_MMIO_DEMO_REG_DATA), ==,
+                    QB_MMIO_DEMO_DATA_MASK);
+
+    qtest_quit(qts);
+}
+
+static void test_pending_irq_and_reset(void)
+{
+    QTestState *qts = qb_mmio_demo_start();
+    uint32_t pending;
+
+    qtest_writel(qts, QB_MMIO_DEMO_BASE + QB_MMIO_DEMO_REG_CONTROL,
+                 QB_MMIO_DEMO_CONTROL_ENABLE |
+                 QB_MMIO_DEMO_CONTROL_IRQ_ENABLE);
+    qtest_writel(qts, QB_MMIO_DEMO_BASE + QB_MMIO_DEMO_REG_DOORBELL, 1);
+
+    g_assert_cmphex(qtest_readl(qts, QB_MMIO_DEMO_BASE +
+                                QB_MMIO_DEMO_REG_STATUS), ==,
+                    QB_MMIO_DEMO_STATUS_PENDING);
+    pending = qtest_readl(qts, VIRT_PLIC_PENDING_BASE);
+    g_assert_cmphex(pending & BIT(VIRT_QB_MMIO_DEMO_IRQ), !=, 0);
+
+    qtest_writel(qts, QB_MMIO_DEMO_BASE + QB_MMIO_DEMO_REG_STATUS,
+                 QB_MMIO_DEMO_STATUS_PENDING);
+    g_assert_cmphex(qtest_readl(qts, QB_MMIO_DEMO_BASE +
+                                QB_MMIO_DEMO_REG_STATUS), ==, 0);
+
+    qtest_writel(qts, QB_MMIO_DEMO_BASE + QB_MMIO_DEMO_REG_DATA, 0x5a);
+    qtest_system_reset(qts);
+    g_assert_cmphex(qtest_readl(qts, QB_MMIO_DEMO_BASE +
+                                QB_MMIO_DEMO_REG_CONTROL), ==, 0);
+    g_assert_cmphex(qtest_readl(qts, QB_MMIO_DEMO_BASE +
+                                QB_MMIO_DEMO_REG_DATA), ==, 0);
+    g_assert_cmphex(qtest_readl(qts, QB_MMIO_DEMO_BASE +
+                                QB_MMIO_DEMO_REG_STATUS), ==, 0);
+
+    qtest_quit(qts);
+}
+
+int main(int argc, char **argv)
+{
+    g_test_init(&argc, &argv, NULL);
+
+    qtest_add_func("/qb-mmio-demo/opt-in-default", test_opt_in_default);
+    qtest_add_func("/qb-mmio-demo/register-masks", test_register_masks);
+    qtest_add_func("/qb-mmio-demo/pending-irq-reset",
+                   test_pending_irq_and_reset);
+
+    return g_test_run();
+}
