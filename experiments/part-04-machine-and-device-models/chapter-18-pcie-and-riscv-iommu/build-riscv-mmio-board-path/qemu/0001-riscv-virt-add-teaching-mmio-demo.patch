diff --git a/include/hw/misc/qb_mmio_demo.h b/include/hw/misc/qb_mmio_demo.h
new file mode 100644
index 0000000..f219dec
--- /dev/null
+++ b/include/hw/misc/qb_mmio_demo.h
@@ -0,0 +1,33 @@
+/*
+ * QEMU Book teaching MMIO device
+ *
+ * SPDX-License-Identifier: GPL-2.0-or-later
+ */
+
+#ifndef HW_MISC_QB_MMIO_DEMO_H
+#define HW_MISC_QB_MMIO_DEMO_H
+
+#include "qemu/bitops.h"
+#include "hw/core/irq.h"
+#include "hw/core/sysbus.h"
+
+#define TYPE_QB_MMIO_DEMO "qb-mmio-demo"
+OBJECT_DECLARE_SIMPLE_TYPE(QBMMIODemoState, QB_MMIO_DEMO)
+
+#define QB_MMIO_DEMO_MMIO_SIZE      0x1000
+#define QB_MMIO_DEMO_ID_VALUE       0x51424d4d
+
+#define QB_MMIO_DEMO_REG_ID         0x00
+#define QB_MMIO_DEMO_REG_CONTROL    0x04
+#define QB_MMIO_DEMO_REG_STATUS     0x08
+#define QB_MMIO_DEMO_REG_DATA       0x0c
+#define QB_MMIO_DEMO_REG_DOORBELL   0x10
+
+#define QB_MMIO_DEMO_CONTROL_ENABLE      BIT(0)
+#define QB_MMIO_DEMO_CONTROL_IRQ_ENABLE  BIT(1)
+#define QB_MMIO_DEMO_CONTROL_MASK        0x3
+
+#define QB_MMIO_DEMO_STATUS_PENDING      BIT(0)
+#define QB_MMIO_DEMO_DATA_MASK           0xff
+
+#endif
